flowchart TD
  %% Node Definitions
  start("START")
  gather_input["Gather Input Data"]
  check_share(["Share provided?"])
  use_share["inputData = share content"]
  check_clipboard(["Clipboard has content?"])
  ask_clipboard["Ask: Use clipboard content?"]
  empty_input["inputData = empty"]
  use_clipboard["inputData = clipboard"]
  ai_suggest["Generate AI suggestions:<br/>• presetTitle = AI(inputData → title)<br/>• presetDescription = AI(inputData → description)"]
  ask_title["Ask for title<br/>(preset: presetTitle)"]
  ask_desc["Ask for description<br/>(preset: presetDescription)"]
  ask_enhance["Ask: Enhance description with AI?"]
  enhance_desc["Enhanced description = AI(current description)"]
  keep_desc["Keep current description"]
  create_ticket["Create Linear ticket"]
  finish("END")

  %% Connections
  start --> gather_input
  gather_input --> check_share
  check_share -- Yes --> use_share
  check_share -- No --> check_clipboard
  check_clipboard -- Yes --> ask_clipboard
  check_clipboard -- No --> empty_input
  ask_clipboard -- Yes --> use_clipboard
  ask_clipboard -- No --> empty_input
  use_share --> ai_suggest
  use_clipboard --> ai_suggest
  empty_input --> ask_title
  ai_suggest --> ask_title
  ask_title --> ask_desc
  ask_desc --> ask_enhance
  ask_enhance -- Yes --> enhance_desc
  ask_enhance -- No --> keep_desc
  enhance_desc --> create_ticket
  keep_desc --> create_ticket
  create_ticket --> finish

  %% Styling
  start:::endpoint
  gather_input:::action
  check_share:::decision
  use_share:::variable
  check_clipboard:::decision
  ask_clipboard:::question
  empty_input:::variable
  use_clipboard:::variable
  ai_suggest:::variable
  ask_title:::question
  ask_desc:::question
  ask_enhance:::question
  enhance_desc:::variable
  keep_desc:::variable
  create_ticket:::action
  finish:::endpoint
