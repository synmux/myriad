# -----------------------------------------------------------------------------
# env.example.template — annotated reference showing what populated values
# look like for typical host setups.
#
# This file is NOT loaded by Docker Compose. It exists purely as a worked
# example. Use env.template as the starting point for your own .env:
#
#   cp env.template .env
#
# then edit your .env using the guidance below.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# PUID / PGID — file ownership inside the containers
# -----------------------------------------------------------------------------
# linuxserver.io images run their processes as a user with these IDs. Files
# written into bind-mounted volumes (./config/*, ./media-data/*) end up owned
# by this user on the host filesystem.
#
# How to pick:
#
#   Linux host (bare metal or VM):
#     Run `id -u` and `id -g` on the host as the user that should own the
#     media. On Ubuntu/Debian/Fedora desktops the first user is usually
#     1000:1000. On a NAS or a server with a dedicated `media` user, it'll
#     be something else — check with `id media`.
#       PUID=1000
#       PGID=1000
#
#   macOS host (Docker Desktop):
#     Docker Desktop runs containers in a Linux VM that normalises ownership
#     between the VM and macOS, so the literal numbers matter less. Leaving
#     the defaults is fine. If you do want to align with your macOS user,
#     run `id` and use those values.
#       PUID=501
#       PGID=20
#
#   Synology / QNAP / Unraid:
#     Each platform has its own conventions. Synology often uses 1026:100 for
#     a created user; Unraid uses 99:100 for `nobody:users` by default.
#     Check the platform documentation.
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# TZ — timezone
# -----------------------------------------------------------------------------
# Set this so Sonarr's "today on TV" calendar and SABnzbd's scheduled
# bandwidth limits align with your local clock. Format is `Region/City` from
# the IANA tz database.
#
# Common values:
#
#   Europe/London          — UK (GMT/BST)
#   Europe/Dublin          — Ireland
#   Europe/Berlin          — Central Europe (CET/CEST)
#   America/New_York       — US East coast
#   America/Los_Angeles    — US West coast
#   America/Chicago        — US Central
#   Australia/Sydney       — Eastern Australia
#   Asia/Tokyo             — Japan
#   Asia/Singapore         — Singapore / Malaysia
#   UTC                    — if you prefer logs in UTC and don't care about
#                            local schedules
#
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/London

# -----------------------------------------------------------------------------
# VPN configuration — for the optional gluetun + qbittorrent services
# -----------------------------------------------------------------------------
# Only relevant if you've uncommented the gluetun and qbittorrent blocks in
# docker-compose.yml. Usenet traffic via SABnzbd does NOT need this — only
# BitTorrent benefits from VPN routing.
#
# gluetun supports many VPN providers and both WireGuard and OpenVPN. Pick
# one of the example blocks below and adapt to your account.
#
# Full provider list and required variables:
#   https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers

# -----------------------------------------------------------------------------
# Example A — Mullvad over WireGuard (recommended; fast, anonymous accounts)
# -----------------------------------------------------------------------------
# Generate a WireGuard config at https://mullvad.net/en/account/wireguard-config
# Copy `PrivateKey` → WIREGUARD_PRIVATE_KEY
# Copy `Address`    → WIREGUARD_ADDRESSES (e.g. 10.64.0.2/32)
#
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=YOUR_PRIVATE_KEY_BASE64
# WIREGUARD_ADDRESSES=10.64.0.2/32
# VPN_SERVER_COUNTRIES=Switzerland

# -----------------------------------------------------------------------------
# Example B — ProtonVPN over WireGuard (port forwarding supported on paid plans)
# -----------------------------------------------------------------------------
# Generate a WireGuard config at
# https://account.protonvpn.com/downloads (Linux > WireGuard config).
# Note: ProtonVPN's port forwarding requires a P2P-capable server and
# `PORT_FORWARD_ONLY=on` in gluetun env if you want explicit control.
#
# VPN_SERVICE_PROVIDER=protonvpn
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=YOUR_PRIVATE_KEY_BASE64
# WIREGUARD_ADDRESSES=10.2.0.2/32
# VPN_SERVER_COUNTRIES=Netherlands

# -----------------------------------------------------------------------------
# Example C — NordVPN over OpenVPN (no native WireGuard support in gluetun)
# -----------------------------------------------------------------------------
# OpenVPN is slower than WireGuard. Prefer providers with WireGuard support.
# Get OpenVPN credentials from https://my.nordaccount.com/dashboard/nordvpn/
#
# VPN_SERVICE_PROVIDER=nordvpn
# VPN_TYPE=openvpn
# OPENVPN_USER=YOUR_NORDVPN_SERVICE_USERNAME
# OPENVPN_PASSWORD=YOUR_NORDVPN_SERVICE_PASSWORD
# VPN_SERVER_COUNTRIES=Switzerland

# -----------------------------------------------------------------------------
# Notes on country selection
# -----------------------------------------------------------------------------
# VPN_SERVER_COUNTRIES is a hint; gluetun picks any matching server.
# Fast countries near you usually beat far-away ones for throughput.
# Countries with strong privacy law (CH, IS, SE, NL, RO) are popular for
# privacy posture, but the server's distance matters more for speed.

# -----------------------------------------------------------------------------
# put.io configuration — for the optional plundrio service
# -----------------------------------------------------------------------------
# Only relevant if you've uncommented the plundrio block in
# docker-compose.yml. plundrio is an alternative to gluetun + qBittorrent
# that uses put.io's cloud infrastructure to handle torrents — your machine
# never joins the swarm, so no VPN is needed for the torrent path.
#
# Project: https://github.com/elsbrock/plundrio
#
# -----------------------------------------------------------------------------
# How to obtain a put.io OAuth token
# -----------------------------------------------------------------------------
# 1. Sign in at https://put.io and visit https://app.put.io/oauth
# 2. Click "Create New Application":
#       Name:           plundrio-arr (or anything you like)
#       Description:    *arr stack download client
#       Website:        http://localhost
#       Callback URL:   http://localhost (not used by plundrio)
# 3. After saving, the application page shows an "OAuth Token" field.
#    Copy that long string into PUTIO_TOKEN below.
#
# Note: this token is bearer credentials for your put.io account — treat it
# like a password. Putting it in .env (which is .gitignore'd) is fine;
# committing it to source control is not.

# Bearer OAuth token from the steps above.
# PUTIO_TOKEN=oauth_token_string_from_putio_application_page

# Folder name on the put.io side. plundrio organises put.io-side downloads
# under this folder so they're easy to find/clean if plundrio is stopped.
# Any name works; "arr-stack" is just a convention.
# PUTIO_FOLDER=arr-stack

# How many parallel HTTPS downloads to run when pulling completed files
# from put.io to your local /data tree. Higher = faster on a fast link,
# but eats more concurrent connections. 4 is a sensible default.
# PUTIO_WORKERS=4
