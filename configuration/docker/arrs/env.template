# -----------------------------------------------------------------------------
# env.template — copy to .env and edit before `docker compose up -d`.
#
#   cp env.template .env
#
# Docker Compose loads .env automatically from the project directory and
# substitutes the values into ${VAR:-default} placeholders in
# docker-compose.yml. Only the variables actually referenced by the compose
# file are listed here.
#
# For an annotated reference with alternative values for different host
# setups, see env.example.template.
# -----------------------------------------------------------------------------

# User and group IDs that own files written by the *arr containers on the host.
# Match these to the host user that should own the media library and configs.
PUID=1000
PGID=1000

# IANA timezone. Affects Sonarr's calendar, SABnzbd's bandwidth schedule,
# and log timestamps. Full list:
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/London

# -----------------------------------------------------------------------------
# VPN — only required when the gluetun + qbittorrent services are enabled
# in docker-compose.yml. Leave commented otherwise.
# See env.example.template for provider-specific guidance (Mullvad,
# ProtonVPN, NordVPN, AirVPN, PIA, ...).
# -----------------------------------------------------------------------------
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# VPN_SERVER_COUNTRIES=

# -----------------------------------------------------------------------------
# put.io — only required when the plundrio service is enabled in
# docker-compose.yml. See env.example.template for how to obtain an OAuth
# token from https://app.put.io/oauth.
# -----------------------------------------------------------------------------
# PUTIO_TOKEN=
# PUTIO_FOLDER=arr-stack
# PUTIO_WORKERS=4
